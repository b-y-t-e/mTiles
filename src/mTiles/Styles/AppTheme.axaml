<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         DESIGN TOKENS — single source of truth for the app palette.
         Terminal ANSI colors live in TerminalTheme (separate system).
         ============================================================ -->

    <!-- Backgrounds (3 tiers) -->
    <SolidColorBrush x:Key="BgBase"      Color="#1a1a2e" />
    <SolidColorBrush x:Key="BgSurface"   Color="#16162a" />
    <SolidColorBrush x:Key="BgElevated"  Color="#1e1e3a" />

    <!-- Borders (2 tiers) -->
    <SolidColorBrush x:Key="BorderSubtle" Color="#2a2a4a" />
    <SolidColorBrush x:Key="BorderStrong" Color="#3a3a5a" />

    <!-- Text (4 tiers + 1 hover) -->
    <SolidColorBrush x:Key="TextPrimary"   Color="#c0c8e0" />
    <SolidColorBrush x:Key="TextSecondary" Color="#8090b0" />
    <SolidColorBrush x:Key="TextMuted"     Color="#6070a0" />
    <SolidColorBrush x:Key="TextFaint"     Color="#3a3a5a" />
    <SolidColorBrush x:Key="TextHover"     Color="#e0e4f0" />

    <!-- Interactive states -->
    <SolidColorBrush x:Key="InteractiveHover"   Color="#2a2a4a" />
    <SolidColorBrush x:Key="InteractivePressed"  Color="#3a3a5a" />
    <SolidColorBrush x:Key="AccentDefault"       Color="#2d5a8a" />
    <SolidColorBrush x:Key="AccentHover"         Color="#3a6fa0" />

    <!-- Tile type accents -->
    <SolidColorBrush x:Key="TileAccentTerminal" Color="#2d5a8a" />
    <SolidColorBrush x:Key="TileAccentNote"     Color="#8a6d2d" />
    <SolidColorBrush x:Key="TileAccentTodo"     Color="#2d8a5a" />
    <SolidColorBrush x:Key="TileAccentGit"      Color="#7a3d8a" />
    <SolidColorBrush x:Key="TileAccentDatabase" Color="#2d7a8a" />
    <SolidColorBrush x:Key="TileAccentGoal"     Color="#8a5a2d" />

    <!-- Goal phase colors -->
    <SolidColorBrush x:Key="GoalPhaseClarify"   Color="#5a7a8a" />
    <SolidColorBrush x:Key="GoalPhasePlan"      Color="#8a7a5a" />
    <SolidColorBrush x:Key="GoalPhaseImplement" Color="#5a8a6a" />
    <SolidColorBrush x:Key="GoalPhaseReview"    Color="#7a5a8a" />
    <SolidColorBrush x:Key="GoalPhaseSummary"   Color="#6a8a5a" />

    <!-- Danger (close/remove hover) -->
    <SolidColorBrush x:Key="DangerSubtle"  Color="#2e1a24" />
    <SolidColorBrush x:Key="DangerText"    Color="#c06878" />

    <!-- Git tags -->
    <SolidColorBrush x:Key="TagColor"      Color="#6DBF8B" />

    <!-- Status -->
    <SolidColorBrush x:Key="StatusSuccess"       Color="#4a9a6a" />
    <SolidColorBrush x:Key="StatusSuccessSubtle"  Color="#1a2e24" />
    <SolidColorBrush x:Key="StatusSuccessText"    Color="#6abf8a" />
    <SolidColorBrush x:Key="StatusMutedSubtle"    Color="#252528" />

    <!-- Overlay -->
    <SolidColorBrush x:Key="OverlayModal"   Color="#80000000" />

    <!-- Typography sizes -->
    <x:Double x:Key="FontLg">16</x:Double>
    <x:Double x:Key="FontMd">12</x:Double>
    <x:Double x:Key="FontSm">11</x:Double>
    <x:Double x:Key="FontXs">10</x:Double>

    <!-- Spacing -->
    <CornerRadius x:Key="RadiusSm">3</CornerRadius>
    <CornerRadius x:Key="RadiusMd">4</CornerRadius>
    <CornerRadius x:Key="RadiusLg">6</CornerRadius>
    <CornerRadius x:Key="RadiusXl">10</CornerRadius>

    <!-- Override Fluent theme collapsed scrollbar scale (default: scaleX(0.125) → invisible) -->
    <TransformOperations x:Key="VerticalSmallScrollThumbScaleTransform">none</TransformOperations>
    <TransformOperations x:Key="HorizontalSmallScrollThumbScaleTransform">none</TransformOperations>

    <!-- Tab indices -->
    <x:Int32 x:Key="Zero">0</x:Int32>
    <x:Int32 x:Key="One">1</x:Int32>
    <x:Int32 x:Key="Two">2</x:Int32>
    <x:Int32 x:Key="Three">3</x:Int32>

    <Thickness x:Key="BorderThin">1</Thickness>
    <Thickness x:Key="BorderBottom">0,0,0,1</Thickness>
    <Thickness x:Key="BorderTop">0,1,0,0</Thickness>


</ResourceDictionary>
