<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:mTiles.ViewModels"
             xmlns:db="using:mTiles.Services.Database"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="mTiles.Views.DatabaseTileView"
             x:DataType="vm:DatabaseTileViewModel">

    <UserControl.Styles>

        <Style Selector="Button.db-add">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
        </Style>
        <Style Selector="Button.db-add:pointerover">
            <Setter Property="Background" Value="{DynamicResource InteractiveHover}" />
            <Setter Property="Foreground" Value="{DynamicResource TextHover}" />
        </Style>
        <Style Selector="Button.db-add:pressed">
            <Setter Property="Background" Value="{DynamicResource InteractivePressed}" />
        </Style>

        <!-- Tab buttons -->
        <Style Selector="Button.db-tab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="FontSize" Value="{DynamicResource FontXs}" />
            <Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
        </Style>
        <Style Selector="Button.db-tab:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="Button.db-tab:pressed">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.db-tab.db-tab-active">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentDefault}" />
        </Style>
        <Style Selector="Button.db-tab.db-tab-active:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>

    </UserControl.Styles>

    <DockPanel Background="{DynamicResource BgSurface}">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="8,3"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Right: tabs + status pill -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2"
                            VerticalAlignment="Center">
                    <Button Classes="db-tab"
                            Classes.db-tab-active="{Binding IsConfigTab}"
                            Command="{Binding SelectTabCommand}"
                            CommandParameter="0">
                        <TextBlock Text="Config" />
                    </Button>
                    <Button Classes="db-tab"
                            Classes.db-tab-active="{Binding IsLogsTab}"
                            Command="{Binding SelectTabCommand}"
                            CommandParameter="1">
                        <TextBlock Text="Logs" />
                    </Button>
                    <Border Width="6" />
                    <Border CornerRadius="{DynamicResource RadiusSm}" Padding="5,1"
                            Background="{DynamicResource StatusSuccessSubtle}"
                            IsVisible="{Binding IsServiceRunning}">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <Ellipse Width="5" Height="5" VerticalAlignment="Center"
                                     Fill="{DynamicResource StatusSuccess}" />
                            <TextBlock Text="{Binding HttpPort, StringFormat=':{}{0}'}"
                                       FontFamily="{DynamicResource UiFontFamily}"
                                       FontSize="{DynamicResource FontXs}"
                                       Foreground="{DynamicResource StatusSuccessText}" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="{DynamicResource RadiusSm}" Padding="5,1"
                            Background="{DynamicResource DangerSubtle}"
                            IsVisible="{Binding !IsServiceRunning}">
                        <TextBlock Text="Stopped"
                                   FontSize="{DynamicResource FontXs}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DangerText}" />
                    </Border>
                </StackPanel>

                <!-- Left: icon + label -->
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <mi:MaterialIcon Kind="DatabaseOutline" Width="12" Height="12"
                                     Foreground="{DynamicResource TileAccentDatabase}"
                                     VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText}"
                               FontFamily="{DynamicResource UiFontFamily}"
                               FontSize="{DynamicResource UiFontSizeSm}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content area: empty state overlays tabs -->
        <Panel>
            <!-- Service not running — empty state -->
            <StackPanel IsVisible="{Binding !IsServiceRunning}"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Spacing="6">
                <mi:MaterialIcon Kind="DatabaseOffOutline"
                                 Width="28" Height="28"
                                 Foreground="{DynamicResource TextFaint}"
                                 HorizontalAlignment="Center" />
                <TextBlock Text="Enable in Settings → Database"
                           Foreground="{DynamicResource TextFaint}"
                           FontFamily="{DynamicResource UiFontFamily}"
                           FontSize="{DynamicResource UiFontSizeSm}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- ===== Tab 0: Config (Databases) ===== -->
            <DockPanel IsVisible="{Binding IsServiceRunning}">
            <Panel>
                <DockPanel IsVisible="{Binding IsConfigTab}">

                    <!-- Workspace databases — fixed top section -->
                    <Border DockPanel.Dock="Top"
                            Padding="8,5,8,6"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Workspace" Classes="section" Margin="0" />

                            <!-- Empty hint -->
                            <TextBlock Text="Add databases from the list below"
                                       FontFamily="{DynamicResource UiFontFamily}"
                                       FontSize="{DynamicResource FontXs}"
                                       Foreground="{DynamicResource TextFaint}"
                                       IsVisible="{Binding !WorkspaceDatabases.Count}"
                                       Margin="0,1" />

                            <ItemsControl ItemsSource="{Binding WorkspaceDatabases}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:DatabaseItemViewModel">
                                        <Border CornerRadius="{DynamicResource RadiusSm}"
                                                Background="{DynamicResource BgElevated}"
                                                Padding="6,4"
                                                Margin="0,1">
                                            <DockPanel>
                                                <!-- Right: lock toggle + remove -->
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                            Spacing="0" VerticalAlignment="Center">
                                                    <Button Classes="tile-btn"
                                                            Command="{Binding $parent[UserControl].((vm:DatabaseTileViewModel)DataContext).ToggleModificationsCommand}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip.Tip="Toggle write access">
                                                        <Panel>
                                                            <mi:MaterialIcon Kind="LockOutline" Width="11" Height="11"
                                                                             IsVisible="{Binding !AllowModifications}" />
                                                            <mi:MaterialIcon Kind="LockOpenVariantOutline" Width="11" Height="11"
                                                                             Foreground="{DynamicResource StatusSuccessText}"
                                                                             IsVisible="{Binding AllowModifications}" />
                                                        </Panel>
                                                    </Button>
                                                    <Button Classes="tile-btn-close"
                                                            Command="{Binding $parent[UserControl].((vm:DatabaseTileViewModel)DataContext).RemoveFromWorkspaceCommand}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip.Tip="Remove">
                                                        <mi:MaterialIcon Kind="Close" Width="11" Height="11" />
                                                    </Button>
                                                </StackPanel>

                                                <!-- Left: db info -->
                                                <StackPanel VerticalAlignment="Center" Spacing="0">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="{Binding Label}"
                                                                   FontFamily="{DynamicResource UiFontFamily}"
                                                                   FontSize="{DynamicResource UiFontSizeSm}"
                                                                   FontWeight="Medium"
                                                                   Foreground="{DynamicResource TextPrimary}" />
                                                        <Border CornerRadius="{DynamicResource RadiusSm}"
                                                                Padding="4,0"
                                                                Background="{DynamicResource StatusSuccessSubtle}"
                                                                IsVisible="{Binding AllowModifications}">
                                                            <TextBlock Text="RW" FontSize="8"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource StatusSuccessText}" />
                                                        </Border>
                                                        <Border CornerRadius="{DynamicResource RadiusSm}"
                                                                Padding="4,0"
                                                                Background="{DynamicResource StatusMutedSubtle}"
                                                                IsVisible="{Binding !AllowModifications}">
                                                            <TextBlock Text="RO" FontSize="8"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextMuted}" />
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Detected databases — section header + filter -->
                    <Border DockPanel.Dock="Top" Padding="8,5,8,2"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="0">
                        <DockPanel>
                            <TextBlock Text="{Binding AllDatabases.Count, StringFormat='Detected ({0})'}"
                                       Classes="section" Margin="0"
                                       VerticalAlignment="Center" />
                            <TextBox DockPanel.Dock="Right"
                                     Classes="inline-filter"
                                     Text="{Binding DetectedFilterText, Mode=TwoWay}"
                                     Watermark="Filter..."
                                     MaxWidth="160"
                                     Margin="8,0,0,0" />
                        </DockPanel>
                    </Border>

                    <!-- Detected database list — scrollable remainder -->
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding FilteredDatabases}" Margin="4,0,4,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:DatabaseItemViewModel">
                                    <Border CornerRadius="{DynamicResource RadiusSm}"
                                            Padding="6,3"
                                            Margin="0,1">
                                        <DockPanel>
                                            <!-- Right: add button or check -->
                                            <Panel DockPanel.Dock="Right" VerticalAlignment="Center"
                                                   Width="22" Margin="2,0,0,0">
                                                <Button Classes="db-add"
                                                        Command="{Binding $parent[UserControl].((vm:DatabaseTileViewModel)DataContext).AddToWorkspaceCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding !IsInWorkspace}"
                                                        ToolTip.Tip="Add to workspace">
                                                    <mi:MaterialIcon Kind="Plus" Width="12" Height="12" />
                                                </Button>
                                                <mi:MaterialIcon Kind="Check" Width="11" Height="11"
                                                                 Foreground="{DynamicResource StatusSuccessText}"
                                                                 VerticalAlignment="Center"
                                                                 HorizontalAlignment="Center"
                                                                 IsVisible="{Binding IsInWorkspace}" />
                                            </Panel>

                                            <!-- Left: db info -->
                                            <StackPanel VerticalAlignment="Center" Spacing="0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding Label}"
                                                               FontFamily="{DynamicResource UiFontFamily}"
                                                               FontSize="{DynamicResource UiFontSizeSm}"
                                                               Foreground="{DynamicResource TextPrimary}" />
                                                    <Border CornerRadius="{DynamicResource RadiusSm}"
                                                            Padding="4,0"
                                                            Background="{DynamicResource StatusMutedSubtle}">
                                                        <TextBlock Text="{Binding Provider}" FontSize="8"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextMuted}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Server}"
                                                           FontFamily="{DynamicResource UiFontFamily}"
                                                           FontSize="{DynamicResource FontXs}"
                                                           Foreground="{DynamicResource TextFaint}"
                                                           TextTrimming="CharacterEllipsis"
                                                           IsVisible="{Binding HasAlias}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                <!-- ===== Tab 1: Logs ===== -->
                <DockPanel IsVisible="{Binding IsLogsTab}">

                    <!-- Empty state -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="No queries yet"
                               FontFamily="{DynamicResource UiFontFamily}"
                               FontSize="{DynamicResource FontSm}"
                               Foreground="{DynamicResource TextFaint}"
                               HorizontalAlignment="Center"
                               Margin="0,20"
                               IsVisible="{Binding !LogEntries.Count}" />

                    <!-- Log list -->
                    <ScrollViewer x:Name="LogScrollViewer"
                                  IsVisible="{Binding LogEntries.Count}">
                        <ItemsControl ItemsSource="{Binding LogEntries}" Margin="0,2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="db:DbLogEntry">
                                    <Panel>
                                        <!-- System event: divider style -->
                                        <Border Padding="8,4"
                                                IsVisible="{Binding Instance, Converter={x:Static StringConverters.IsNullOrEmpty}}">
                                            <TextBlock Text="{Binding Message}"
                                                       FontFamily="{DynamicResource UiFontFamily}"
                                                       FontSize="{DynamicResource FontXs}"
                                                       Foreground="{DynamicResource TextFaint}"
                                                       FontStyle="Italic"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Border>

                                        <!-- HTTP query row -->
                                        <Border Padding="8,4,8,5"
                                                BorderBrush="{DynamicResource BorderSubtle}"
                                                BorderThickness="0,0,0,1"
                                                IsVisible="{Binding Instance, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Copy SQL"
                                                              Command="{Binding $parent[UserControl].((vm:DatabaseTileViewModel)DataContext).CopySqlCommand}"
                                                              CommandParameter="{Binding}"
                                                              IsVisible="{Binding Sql, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                    <MenuItem Header="Copy error"
                                                              Command="{Binding $parent[UserControl].((vm:DatabaseTileViewModel)DataContext).CopyErrorCommand}"
                                                              CommandParameter="{Binding}"
                                                              IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <StackPanel Spacing="2">
                                                <!-- Row 1: verb chip, instance, status, duration -->
                                                <DockPanel>
                                                    <!-- Right: duration -->
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding ElapsedMs, StringFormat='{}{0}ms'}"
                                                               FontFamily="{DynamicResource UiFontFamily}"
                                                               FontSize="{DynamicResource FontXs}"
                                                               Foreground="{DynamicResource TextMuted}"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0" />
                                                    <StackPanel Orientation="Horizontal" Spacing="5"
                                                                VerticalAlignment="Center">
                                                        <!-- Verb chip -->
                                                        <Border CornerRadius="{DynamicResource RadiusSm}"
                                                                Padding="4,0"
                                                                Background="{DynamicResource StatusMutedSubtle}"
                                                                IsVisible="{Binding !IsWriteVerb}">
                                                            <TextBlock Text="{Binding SqlVerb}" FontSize="8"
                                                                       FontWeight="SemiBold"
                                                                       FontFamily="{DynamicResource UiFontFamily}"
                                                                       Foreground="{DynamicResource TextMuted}" />
                                                        </Border>
                                                        <Border CornerRadius="{DynamicResource RadiusSm}"
                                                                Padding="4,0"
                                                                Background="{DynamicResource DangerSubtle}"
                                                                IsVisible="{Binding IsWriteVerb}">
                                                            <TextBlock Text="{Binding SqlVerb}" FontSize="8"
                                                                       FontWeight="SemiBold"
                                                                       FontFamily="{DynamicResource UiFontFamily}"
                                                                       Foreground="{DynamicResource DangerText}" />
                                                        </Border>
                                                        <!-- Timestamp -->
                                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                                   FontFamily="{DynamicResource UiFontFamily}"
                                                                   FontSize="{DynamicResource FontXs}"
                                                                   Foreground="{DynamicResource TextMuted}" />
                                                        <!-- Instance -->
                                                        <TextBlock Text="{Binding Instance}"
                                                                   FontFamily="{DynamicResource UiFontFamily}"
                                                                   FontSize="{DynamicResource FontXs}"
                                                                   Foreground="{DynamicResource TextMuted}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <!-- Status code -->
                                                        <TextBlock x:Name="StatusText"
                                                                   Text="{Binding StatusCode}"
                                                                   FontFamily="{DynamicResource UiFontFamily}"
                                                                   FontSize="{DynamicResource FontXs}"
                                                                   FontWeight="Bold" />
                                                    </StackPanel>
                                                </DockPanel>
                                                <!-- Row 2: SQL or error -->
                                                <TextBlock Text="{Binding Sql}"
                                                           FontFamily="{DynamicResource UiFontFamily}"
                                                           FontSize="{DynamicResource FontXs}"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           TextWrapping="Wrap"
                                                           MaxLines="3"
                                                           Margin="0,1,0,0"
                                                           IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                                <TextBlock Text="{Binding Error}"
                                                           FontFamily="{DynamicResource UiFontFamily}"
                                                           FontSize="{DynamicResource FontXs}"
                                                           Foreground="{DynamicResource DangerText}"
                                                           FontWeight="Medium"
                                                           TextWrapping="Wrap"
                                                           MaxLines="2"
                                                           Margin="0,1,0,0"
                                                           IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            </StackPanel>
                                        </Border>
                                    </Panel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Panel>
            </DockPanel>
        </Panel>

    </DockPanel>
</UserControl>
