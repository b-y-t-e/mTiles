<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:mTiles.ViewModels"
             xmlns:m="using:mTiles.Models"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="mTiles.Views.LeafTileView"
             x:DataType="vm:LeafTileNodeViewModel"
             DragDrop.AllowDrop="True">

    <Grid>
        <Border ClipToBounds="True" Margin="0,0,0,0">
            <DockPanel>
                <!-- Active indicator strip -->
                <Border x:Name="ActiveStrip"
                        DockPanel.Dock="Top"
                        Height="2"
                        Background="{DynamicResource BgSurface}" />

                <!-- Tile toolbar -->
                <Border x:Name="TileToolbar"
                        DockPanel.Dock="Top"
                        Background="{DynamicResource BgSurface}"
                        Padding="6,0"
                        Height="26">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="1">
                            <Button Classes="tile-btn"
                                    Command="{Binding RestartTerminalCommand}"
                                    ToolTip.Tip="Restart shell (Ctrl+Shift+R)"
                                    IsVisible="{Binding ContentType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static m:TileContentType.Terminal}}">
                                <mi:MaterialIcon Kind="Restart" Width="14" Height="14" />
                            </Button>
                            <Button Classes="tile-btn"
                                    Command="{Binding ResetTileIdCommand}"
                                    ToolTip.Tip="New session"
                                    IsVisible="{Binding HasProfile}">
                                <mi:MaterialIcon Kind="PlaylistPlus" Width="14" Height="14" />
                            </Button>
                            <Button Classes="tile-btn"
                                    Command="{Binding SplitVerticalCommand}"
                                    ToolTip.Tip="Split Right">
                                <mi:MaterialIcon Kind="DockRight" Width="14" Height="14" />
                            </Button>
                            <Button Classes="tile-btn"
                                    Command="{Binding SplitHorizontalCommand}"
                                    ToolTip.Tip="Split Down">
                                <mi:MaterialIcon Kind="DockBottom" Width="14" Height="14" />
                            </Button>
                            <Button Classes="tile-btn-close"
                                    Command="{Binding CloseCommand}"
                                    ToolTip.Tip="Close tile">
                                <mi:MaterialIcon Kind="Close" Width="14" Height="14" />
                            </Button>
                        </StackPanel>

                        <TextBlock x:Name="TileNameLabel"
                                   Text="{Binding TileName}"
                                   VerticalAlignment="Center"
                                   FontFamily="{DynamicResource UiFontFamily}"
                                   FontSize="{DynamicResource UiFontSize}"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="2,0"
                                   Cursor="Hand"
                                   DoubleTapped="TileNameLabel_DoubleTapped" />
                        <TextBox x:Name="TileNameEditor"
                                 Text="{Binding TileName}"
                                 IsVisible="False"
                                 Classes="inline-editor"
                                 LostFocus="TileNameEditor_Confirm"
                                 KeyDown="TileNameEditor_KeyDown" />
                    </DockPanel>
                </Border>

                <!-- Content area + chooser overlay -->
                <Panel Margin="6,0">
                    <WrapPanel x:Name="ContentChooser"
                               IsVisible="False"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Orientation="Horizontal">
                        <Button Classes="chooser-card"
                                Command="{Binding SelectContentTypeCommand}"
                                CommandParameter="{x:Static m:TileContentType.Terminal}">
                            <Grid>
                                <Border Background="{DynamicResource TileAccentTerminal}"
                                        Width="3" CornerRadius="2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Margin="-16,0,0,0" />
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <mi:MaterialIcon Kind="Console" Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     Foreground="{DynamicResource TileAccentTerminal}" />
                                    <TextBlock Text="Terminal" FontSize="{DynamicResource FontSm}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Classes="chooser-card"
                                Command="{Binding SelectContentTypeCommand}"
                                CommandParameter="{x:Static m:TileContentType.Note}">
                            <Grid>
                                <Border Background="{DynamicResource TileAccentNote}"
                                        Width="3" CornerRadius="2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Margin="-16,0,0,0" />
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <mi:MaterialIcon Kind="NoteEditOutline" Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     Foreground="{DynamicResource TileAccentNote}" />
                                    <TextBlock Text="Note" FontSize="{DynamicResource FontSm}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Classes="chooser-card"
                                Command="{Binding SelectContentTypeCommand}"
                                CommandParameter="{x:Static m:TileContentType.Todo}">
                            <Grid>
                                <Border Background="{DynamicResource TileAccentTodo}"
                                        Width="3" CornerRadius="2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Margin="-16,0,0,0" />
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <mi:MaterialIcon Kind="CheckboxMarkedOutline" Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     Foreground="{DynamicResource TileAccentTodo}" />
                                    <TextBlock Text="Todo" FontSize="{DynamicResource FontSm}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Classes="chooser-card"
                                Command="{Binding SelectContentTypeCommand}"
                                CommandParameter="{x:Static m:TileContentType.Git}">
                            <Grid>
                                <Border Background="{DynamicResource TileAccentGit}"
                                        Width="3" CornerRadius="2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Margin="-16,0,0,0" />
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <mi:MaterialIcon Kind="SourceBranch" Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     Foreground="{DynamicResource TileAccentGit}" />
                                    <TextBlock Text="Git" FontSize="{DynamicResource FontSm}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Classes="chooser-card"
                                Command="{Binding SelectContentTypeCommand}"
                                CommandParameter="{x:Static m:TileContentType.Database}">
                            <Grid>
                                <Border Background="{DynamicResource TileAccentDatabase}"
                                        Width="3" CornerRadius="2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Margin="-16,0,0,0" />
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <mi:MaterialIcon Kind="DatabaseOutline" Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     Foreground="{DynamicResource TileAccentDatabase}" />
                                    <TextBlock Text="Database" FontSize="{DynamicResource FontSm}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Classes="chooser-card"
                                Command="{Binding SelectContentTypeCommand}"
                                CommandParameter="{x:Static m:TileContentType.Goal}">
                            <Grid>
                                <Border Background="{DynamicResource TileAccentGoal}"
                                        Width="3" CornerRadius="2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Margin="-16,0,0,0" />
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <mi:MaterialIcon Kind="BullseyeArrow" Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     Foreground="{DynamicResource TileAccentGoal}" />
                                    <TextBlock Text="Goal" FontSize="{DynamicResource FontSm}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </WrapPanel>

                    <!-- Profile chooser -->
                    <WrapPanel x:Name="ProfileChooser"
                               IsVisible="False"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Orientation="Horizontal">
                        <Button Classes="chooser-back"
                                Command="{Binding CancelProfileSelectionCommand}">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <mi:MaterialIcon Kind="ArrowLeft" Width="22" Height="22"
                                                 HorizontalAlignment="Center"
                                                 Foreground="{DynamicResource TextMuted}" />
                                <TextBlock Text="Back" FontSize="{DynamicResource FontSm}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ProfileButtonsMarker"
                                Classes="chooser-card"
                                Command="{Binding SelectDefaultTerminalCommand}">
                            <Grid>
                                <Border Background="{DynamicResource TileAccentTerminal}"
                                        Width="3" CornerRadius="2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Margin="-16,0,0,0" />
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <mi:MaterialIcon Kind="Console" Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     Foreground="{DynamicResource TextMuted}" />
                                    <TextBlock Text="Default shell" FontSize="{DynamicResource FontSm}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </WrapPanel>

                    <Panel x:Name="ContentHost" />
                </Panel>
            </DockPanel>
        </Border>

        <!-- Drop zone overlay -->
        <Border x:Name="DropOverlay" IsVisible="False" IsHitTestVisible="False"
                CornerRadius="4" ZIndex="100" />
    </Grid>
</UserControl>
