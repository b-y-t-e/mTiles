<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MTerminal.ViewModels"
             x:Class="MTerminal.Views.LeafPaneView"
             x:DataType="vm:LeafPaneNodeViewModel">

    <UserControl.Styles>
        <Style Selector="Button.pane-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#6070a0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="MinHeight" Value="20" />
        </Style>
        <Style Selector="Button.pane-btn:pointerover">
            <Setter Property="Background" Value="#2a2a4a" />
            <Setter Property="Foreground" Value="#b0b8d0" />
        </Style>
        <Style Selector="Button.pane-btn:pressed">
            <Setter Property="Background" Value="#3a3a5a" />
        </Style>
        <Style Selector="TextBox.clearFocus:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#3a3a5a" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Styles>

    <Border BorderBrush="#252540"
            BorderThickness="1"
            CornerRadius="3"
            ClipToBounds="True">
        <DockPanel>
            <!-- Pane toolbar -->
            <Border DockPanel.Dock="Top"
                    Background="#16162a"
                    Padding="6,0"
                    Height="26">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="1">
                        <Button Classes="pane-btn" ToolTip.Tip="Split pane">
                            <Button.Content>
                                <TextBlock Text="+" FontSize="12" FontWeight="Bold" />
                            </Button.Content>
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuItem Header="Split Right - Terminal"
                                              Command="{Binding SplitVerticalTerminalCommand}" />
                                    <MenuItem Header="Split Right - Editor"
                                              Command="{Binding SplitVerticalEditorCommand}" />
                                    <Separator />
                                    <MenuItem Header="Split Down - Terminal"
                                              Command="{Binding SplitHorizontalTerminalCommand}" />
                                    <MenuItem Header="Split Down - Editor"
                                              Command="{Binding SplitHorizontalEditorCommand}" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <Button Classes="pane-btn"
                                Command="{Binding CloseCommand}"
                                ToolTip.Tip="Close pane">
                            <TextBlock Text="x" FontSize="11" />
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="PaneNameLabel"
                               Text="{Binding PaneName}"
                               VerticalAlignment="Center"
                               FontSize="10"
                               Foreground="#4a5070"
                               Margin="2,0"
                               Cursor="Hand"
                               DoubleTapped="PaneNameLabel_DoubleTapped" />
                    <TextBox x:Name="PaneNameEditor"
                             Text="{Binding PaneName}"
                             IsVisible="False"
                             FontSize="10"
                             Foreground="#c0c8e0"
                             Background="#252540"
                             BorderBrush="#3a3a5a"
                             BorderThickness="1"
                             Classes="clearFocus"
                             CornerRadius="2"
                             Padding="4,1"
                             Margin="2,0"
                             Height="20"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             MinWidth="60"
                             LostFocus="PaneNameEditor_Confirm"
                             KeyDown="PaneNameEditor_KeyDown" />
                </DockPanel>
            </Border>

            <!-- Content area: managed in code-behind -->
            <Panel x:Name="ContentHost" />
        </DockPanel>
    </Border>
</UserControl>
