<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MTerminal.ViewModels"
        xmlns:views="using:MTerminal.Views"
        xmlns:mi="using:Material.Icons.Avalonia"
        x:Class="MTerminal.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MTerminal"
        Icon="/Assets/mterminal-icon.png"
        Background="{DynamicResource BgBase}">

    <DockPanel>
        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgSurface}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,3"
                Padding="4,0"
                Height="38">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="2">
                    <Button Classes="toolbar"
                            Command="{Binding TogglePanelCommand}"
                            ToolTip.Tip="Toggle Workspaces Panel">
                        <mi:MaterialIcon Kind="Menu" Width="18" Height="18" />
                    </Button>
                    <TextBlock Text="MTerminal" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"
                               FontFamily="{DynamicResource UiFontFamily}"
                               FontWeight="SemiBold" FontSize="{DynamicResource LogoFontSize}" Margin="8,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2">
                    <Button Classes="toolbar"
                            Command="{Binding ToggleSettingsCommand}"
                            ToolTip.Tip="Settings">
                        <mi:MaterialIcon Kind="CogOutline" Width="18" Height="18" />
                    </Button>
                </StackPanel>
                <Panel />
            </DockPanel>
        </Border>

        <!-- Main content with resizable panel -->
        <Panel>
            <Grid x:Name="MainGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" MinWidth="150" MaxWidth="500" />
                    <ColumnDefinition Width="3" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Workspaces panel -->
                <views:WorkspacesPanelView Grid.Column="0"
                                           DataContext="{Binding WorkspacesPanel}" />

                <!-- Resizer -->
                <GridSplitter x:Name="PanelSplitter" Grid.Column="1"
                              ResizeDirection="Columns" />

                <!-- Workspace content -->
                <Panel Grid.Column="2">
                    <Panel x:Name="WorkspaceHost" />
                    <TextBlock Text="Select or add a workspace to get started"
                               IsVisible="{Binding CurrentWorkspace, Converter={x:Static ObjectConverters.IsNull}}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource FontLg}"
                               Foreground="{DynamicResource TextFaint}" />
                </Panel>
            </Grid>

            <!-- Settings overlay -->
            <Panel IsVisible="{Binding IsSettingsOpen}">
                <Border Background="{DynamicResource OverlayModal}"
                        PointerPressed="SettingsOverlay_PointerPressed" />
                <Border x:Name="SettingsDialog"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinWidth="420"
                        MinHeight="400"
                        CornerRadius="{DynamicResource RadiusXl}"
                        Background="{DynamicResource BgElevated}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="{DynamicResource BorderThin}"
                        BoxShadow="0 8 32 0 #60000000"
                        Padding="0"
                        PointerPressed="SettingsDialog_PointerPressed">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="16,10,16,0"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="{DynamicResource BorderBottom}">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Classes="toolbar"
                                        Command="{Binding ToggleSettingsCommand}"
                                        VerticalAlignment="Top" Margin="0,2,0,0">
                                    <mi:MaterialIcon Kind="Close" Width="16" Height="16" />
                                </Button>
                                <StackPanel Orientation="Horizontal" Spacing="0">
                                    <Button Classes="settings-tab"
                                            Classes.settings-tab-active="{Binding Settings.IsGeneralTab}"
                                            Command="{Binding Settings.SelectTabCommand}"
                                            CommandParameter="{StaticResource Zero}"
                                            Content="General" />
                                    <Button Classes="settings-tab"
                                            Classes.settings-tab-active="{Binding Settings.IsProfilesTab}"
                                            Command="{Binding Settings.SelectTabCommand}"
                                            CommandParameter="{StaticResource One}"
                                            Content="Profiles" />
                                    <Button Classes="settings-tab"
                                            Classes.settings-tab-active="{Binding Settings.IsAiToolsTab}"
                                            Command="{Binding Settings.SelectTabCommand}"
                                            CommandParameter="{StaticResource Two}"
                                            Content="AI Tools" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0">
                            <ContentControl Content="{Binding Settings}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Panel>
        </Panel>
    </DockPanel>
</Window>
