<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MTerminal.ViewModels"
             xmlns:m="using:MTerminal.Models"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="MTerminal.Views.WorkspacesPanelView"
             x:DataType="vm:WorkspacesPanelViewModel"
             Background="{DynamicResource BgSurface}">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <ListBox x:Name="WorkspaceList"
                     Classes="sidebar-list"
                     ItemsSource="{Binding Workspaces}"
                     SelectedItem="{Binding SelectedWorkspace}"
                     Background="Transparent"
                     Margin="3, 4">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="m:Workspace">
                        <DockPanel Margin="0,0,0, 0">
                           <!-- <Button DockPanel.Dock="Right"
                                    Content="&#215;" Classes="ghost"
                                    Command="{Binding #WorkspaceList.((vm:WorkspacesPanelViewModel)DataContext).RemoveWorkspaceCommand}"
                                    CommandParameter="{Binding}"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Remove workspace" />-->
                            <StackPanel Spacing="1">
                                <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text="{Binding DirectoryPath}"
                                           Foreground="{DynamicResource TextMuted}"
                                           FontSize="{DynamicResource UiFontSizeSm}"
                                           TextTrimming="CharacterEllipsis"
                                           Opacity="0.8" />
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Classes="add-workspace"
                    Command="{Binding AddWorkspaceCommand}"
                    Margin="8,0, 8, 2"
                    HorizontalAlignment="Stretch"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <mi:MaterialIcon Kind="Plus" Width="16" Height="16" />
                    <TextBlock Text="Workspace" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
