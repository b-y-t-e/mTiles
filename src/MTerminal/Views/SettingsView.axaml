<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MTerminal.ViewModels"
             x:Class="MTerminal.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#6070a0" />
        </Style>
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#6070a0" />
            <Setter Property="LetterSpacing" Value="1.5" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>
        <Style Selector="TextBox.setting">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="#16162a" />
            <Setter Property="Foreground" Value="#c0c8e0" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="ComboBox.setting">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="#16162a" />
            <Setter Property="Foreground" Value="#c0c8e0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="NumericUpDown.setting">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="#16162a" />
            <Setter Property="Foreground" Value="#c0c8e0" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="12" Margin="16">
        <!-- Default Shell -->
        <StackPanel Spacing="4">
            <TextBlock Text="Default Shell" Classes="label" />
            <ComboBox Classes="setting"
                      SelectedItem="{Binding SelectedShell}"
                      ItemsSource="{Binding ShellOptions}" />
            <StackPanel Spacing="4" IsVisible="{Binding IsCustomShell}">
                <TextBox Classes="setting"
                         Text="{Binding CustomShellPath}"
                         PlaceholderText="Path to executable" />
                <TextBox Classes="setting"
                         Text="{Binding CustomShellArgs}"
                         PlaceholderText="Arguments (optional)" />
            </StackPanel>
        </StackPanel>

        <!-- Terminal -->
        <TextBlock Text="TERMINAL" Classes="section" />
        <StackPanel Spacing="4">
            <TextBlock Text="Color Theme" Classes="label" />
            <ComboBox Classes="setting"
                      SelectedItem="{Binding TerminalThemeName}"
                      ItemsSource="{x:Static vm:SettingsViewModel.TerminalThemeNames}" />
            <TextBlock Text="Font Family" Classes="label" />
            <TextBox Classes="setting"
                     Text="{Binding TerminalFontFamily}"
                     PlaceholderText="Font family" />
            <TextBlock Text="Font Size" Classes="label" />
            <NumericUpDown Classes="setting"
                           Value="{Binding TerminalFontSize}" Minimum="8" Maximum="48" Increment="1" />
        </StackPanel>

        <!-- Editor -->
        <TextBlock Text="EDITOR" Classes="section" />
        <StackPanel Spacing="4">
            <TextBlock Text="Font Family" Classes="label" />
            <TextBox Classes="setting"
                     Text="{Binding EditorFontFamily}"
                     PlaceholderText="Font family" />
            <TextBlock Text="Font Size" Classes="label" />
            <NumericUpDown Classes="setting"
                           Value="{Binding EditorFontSize}" Minimum="8" Maximum="48" Increment="1" />
        </StackPanel>

        <!-- Appearance -->
        <TextBlock Text="APPEARANCE" Classes="section" />
        <StackPanel Spacing="4">
            <TextBlock Text="Theme" Classes="label" />
            <ComboBox Classes="setting"
                      SelectedItem="{Binding Theme}"
                      ItemsSource="{x:Static vm:SettingsViewModel.Themes}" />
        </StackPanel>
    </StackPanel>
</UserControl>
