<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="using:AvaloniaEdit">

    <!-- ======== BUTTON: toolbar ======== -->
    <Style Selector="Button.toolbar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="FontSize" Value="{DynamicResource FontMd}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.toolbar:pointerover">
        <Setter Property="Background" Value="{DynamicResource InteractiveHover}" />
        <Setter Property="Foreground" Value="{DynamicResource TextHover}" />
    </Style>
    <Style Selector="Button.toolbar:pressed">
        <Setter Property="Background" Value="{DynamicResource InteractivePressed}" />
    </Style>

    <!-- ======== BUTTON: accent ======== -->
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource AccentDefault}" />
        <Setter Property="Foreground" Value="{DynamicResource TextHover}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}" />
        <Setter Property="FontSize" Value="{DynamicResource FontMd}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.accent:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHover}" />
    </Style>
    <Style Selector="Button.accent:pressed">
        <Setter Property="Background" Value="{DynamicResource AccentHover}" />
    </Style>

    <!-- ======== BUTTON: outlined (Add Workspace style) ======== -->
    <Style Selector="Button.outlined">
        <Setter Property="Background" Value="{DynamicResource BgElevated}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}" />
        <Setter Property="FontSize" Value="{DynamicResource FontMd}" />
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThin}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.outlined:pointerover">
        <Setter Property="Background" Value="{DynamicResource InteractiveHover}" />
        <Setter Property="Foreground" Value="{DynamicResource TextHover}" />
    </Style>
    <Style Selector="Button.outlined:pressed">
        <Setter Property="Background" Value="{DynamicResource InteractivePressed}" />
    </Style>

    <!-- ======== BUTTON: tile-btn ======== -->
    <Style Selector="Button.tile-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSm}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinWidth" Value="24" />
        <Setter Property="MinHeight" Value="20" />
    </Style>
    <Style Selector="Button.tile-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource InteractiveHover}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>
    <Style Selector="Button.tile-btn:pressed">
        <Setter Property="Background" Value="{DynamicResource InteractivePressed}" />
    </Style>

    <!-- ======== BUTTON: chooser-card (tile type picker) ======== -->
    <Style Selector="Button.chooser-card">
        <Setter Property="Background" Value="{DynamicResource BgElevated}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="Padding" Value="20,14" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}" />
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThin}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.chooser-card:pointerover">
        <Setter Property="Background" Value="{DynamicResource InteractiveHover}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
        <Setter Property="Foreground" Value="{DynamicResource TextHover}" />
    </Style>
    <Style Selector="Button.chooser-card:pressed">
        <Setter Property="Background" Value="{DynamicResource InteractivePressed}" />
    </Style>

    <!-- ======== BUTTON: ghost (remove/close, minimal) ======== -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="MinWidth" Value="22" />
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="FontSize" Value="{DynamicResource FontSm}" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.ghost:pointerover">
        <Setter Property="Background" Value="{DynamicResource DangerSubtle}" />
        <Setter Property="Foreground" Value="{DynamicResource DangerText}" />
    </Style>
    <Style Selector="Button.ghost:pressed">
        <Setter Property="Background" Value="{DynamicResource DangerSubtle}" />
        <Setter Property="Foreground" Value="{DynamicResource DangerText}" />
    </Style>

    <!-- ======== BUTTON: tile-btn-close (tile close with danger hover) ======== -->
    <Style Selector="Button.tile-btn-close">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSm}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinWidth" Value="24" />
        <Setter Property="MinHeight" Value="20" />
    </Style>
    <Style Selector="Button.tile-btn-close:pointerover">
        <Setter Property="Background" Value="{DynamicResource DangerSubtle}" />
        <Setter Property="Foreground" Value="{DynamicResource DangerText}" />
    </Style>
    <Style Selector="Button.tile-btn-close:pressed">
        <Setter Property="Background" Value="{DynamicResource DangerSubtle}" />
        <Setter Property="Foreground" Value="{DynamicResource DangerText}" />
    </Style>

    <!-- ======== LISTBOX: sidebar-list (workspace list etc.) ======== -->
    <Style Selector="ListBox.sidebar-list ListBoxItem">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Margin" Value="4,1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}" />
    </Style>
    <Style Selector="ListBox.sidebar-list ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource InteractiveHover}" />
    </Style>
    <Style Selector="ListBox.sidebar-list ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource InteractiveHover}" />
    </Style>

    <!-- ======== TEXT: section header ======== -->
    <Style Selector="TextBlock.section">
        <Setter Property="FontSize" Value="{DynamicResource FontSm}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        <Setter Property="LetterSpacing" Value="1.5" />
        <Setter Property="Margin" Value="0,8,0,0" />
    </Style>

    <!-- ======== TEXT: label ======== -->
    <Style Selector="TextBlock.label">
        <Setter Property="FontSize" Value="{DynamicResource FontSm}" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    </Style>

    <!-- ======== TEXT: caption (small meta text) ======== -->
    <Style Selector="TextBlock.caption">
        <Setter Property="FontSize" Value="{DynamicResource FontSm}" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    </Style>

    <!-- ======== FORM: setting controls ======== -->
    <Style Selector="TextBox.setting">
        <Setter Property="FontSize" Value="{DynamicResource FontMd}" />
        <Setter Property="Background" Value="{DynamicResource BgSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
    </Style>
    <Style Selector="ComboBox.setting">
        <Setter Property="FontSize" Value="{DynamicResource FontMd}" />
        <Setter Property="Background" Value="{DynamicResource BgSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="NumericUpDown.setting">
        <Setter Property="FontSize" Value="{DynamicResource FontMd}" />
        <Setter Property="Background" Value="{DynamicResource BgSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
    </Style>

    <!-- ======== TEXTBOX: inline editor (tile name) ======== -->
    <Style Selector="TextBox.inline-editor">
        <Setter Property="FontSize" Value="{DynamicResource FontMd}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource BgSurface}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentDefault}" />
        <Setter Property="SelectionForegroundBrush" Value="{DynamicResource TextHover}" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextSecondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentDefault}" />
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThin}" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Height" Value="22" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinWidth" Value="60" />
    </Style>
    <Style Selector="TextBox.inline-editor:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentDefault}" />
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThin}" />
    </Style>

    <!-- ======== SCROLLBAR: disable Fluent auto-hide, custom thumb color ======== -->
    <Style Selector="ScrollBar">
        <Setter Property="AllowAutoHide" Value="False" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource BorderSubtle}" />
    </Style>
    <Style Selector="ScrollBar:pointerover /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource BorderStrong}" />
    </Style>
    <Style Selector="ScrollBar /template/ RepeatButton">
        <Setter Property="IsVisible" Value="False" />
    </Style>

</Styles>
